# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA commitar o ".env" real no Git (já está no .gitignore).

# Porta do servidor (Render/Railway definem PORT automaticamente)
PORT=3000

# Senha do painel de leads (/admin) — escolha uma senha forte
ADMIN_PASSWORD=

# Chave usada para assinar a sessão de login — qualquer texto aleatório longo
SESSION_SECRET=

# Envio de e-mail de notificação a cada novo lead (opcional).
# Se deixar em branco, o site continua funcionando e salvando os leads,
# só não envia e-mail — os leads ficam visíveis em /admin.
# Para Gmail: gerar uma "Senha de App" em myaccount.google.com/apppasswords
# (não usar a senha normal da conta).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Para onde o e-mail de notificação de novo lead é enviado
CONTATO_DESTINO=Revenup001@gmail.com

NODE_ENV=production
